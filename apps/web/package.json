{
  "name": "@keeppage/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:mock": "VITE_APP_MODE=mock vite",
    "dev:demo": "vite --open /demo.html",
    "dev:demo:mock": "VITE_APP_MODE=mock vite --open /demo.html",
    "build": "tsc -p tsconfig.json && vite build",
    "build:demo:html": "VITE_APP_MODE=mock vite build --config vite.standalone-demo.config.mjs && node ./scripts/build-standalone-demo.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@keeppage/domain": "*",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "typescript": "^5.9.3",
    "vite": "^7.1.12"
  }
}
